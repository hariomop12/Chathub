              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "health"
              ]
            },
            "description": "Checks database connectivity and PeerJS reachability."
          }
        },
        {
          "name": "Full Health",
          "request": {
            "method": "GET",
            "header": [],
            "auth": {
              "type": "noauth"
            },
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            },
            "description": "Alias for the API health check."
          }
        }
      ]
    },
    {
      "name": "Helpers",
      "item": [
        {
          "name": "Get Clerk Token Helper",
          "request": {
            "method": "GET",
            "header": [],
            "auth": {
              "type": "noauth"
            },
            "url": {
              "raw": "https://clerk.com/docs/guides/development/testing/postman-or-insomnia",
              "protocol": "https",
              "host": [
                "clerk",
                "com"
              ],
              "path": [
                "docs",
                "guides",
                "development",
                "testing",
                "postman-or-insomnia"
              ]
            },
            "description": "Use this as the reference flow for getting a live Clerk session token for Postman.\n\nSteps:\n1. Open your app in the browser and sign in with Clerk.\n2. Open DevTools Console.\n3. Run `await window.Clerk.session.getToken()`.\n4. Copy the returned JWT.\n5. Paste it into the `bearerToken` variable in the `ChatHub Local` environment.\n6. If you use a custom Clerk JWT template, run `await window.Clerk.session.getToken({ template: '{{clerkTemplate}}' })` after setting `clerkTemplate` in the environment.\n\nIf you want a quick sanity check, keep this request as a clickable docs shortcut inside the collection."
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [],
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{bearerToken}}",
                  "type": "string"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/users",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users"
              ]
            },
            "description": "Returns all users visible to the authenticated session."
          }
        },
        {
          "name": "Upsert Current User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{bearerToken}}",
                  "type": "string"
                }
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"hariom\",\n  \"email\": \"hariom@example.com\",\n  \"avatar\": \"https://img.clerk.com/avatar.jpg\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users"
              ]
            },
            "description": "Creates or updates the current Clerk user."
          }
        },
        {
          "name": "Search Users",
          "request": {
            "method": "GET",
            "header": [],
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{bearerToken}}",
                  "type": "string"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/search?q={{query}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "search"
              ],
              "query": [
                {
                  "key": "q",
                  "value": "{{query}}"
                }
              ]
            },
            "description": "Searches users by username or email."
          }
        }
      ]
    },
    {
      "name": "Chats",
      "item": [
        {
          "name": "Get My Chats",
          "request": {
            "method": "GET",
            "header": [],
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{bearerToken}}",
                  "type": "string"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/chats",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "chats"
              ]
            },
            "description": "Returns the authenticated user's direct and group chats."
          }
        },
        {
          "name": "Create Chat",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{bearerToken}}",
                  "type": "string"
                }
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"participantIds\": [\"user_2abc123\", \"{{participantUserId}}\"],\n  \"name\": \"Group Chat\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/chats",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "chats"
              ]
            },
            "description": "Creates a direct chat or group chat depending on participant count."
          }
        },
        {
          "name": "Get Chat By ID",
          "request": {
            "method": "GET",
            "header": [],
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{bearerToken}}",
                  "type": "string"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/chats/{{chatId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "chats",
                "{{chatId}}"
              ]
            },
            "description": "Fetches a single chat by UUID."
          }
        },
        {
          "name": "Delete Direct Chat",
          "request": {
            "method": "DELETE",
            "header": [],
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{bearerToken}}",
                  "type": "string"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/chats/{{chatId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "chats",
                "{{chatId}}"
              ]
            },
            "description": "Deletes a direct chat owned by the authenticated user."
          }
        }
      ]
    },
    {
