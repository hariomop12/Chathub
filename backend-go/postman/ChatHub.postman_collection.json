            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Hey bro!\",\n  \"fileUrl\": \"\",\n  \"fileName\": \"\",\n  \"fileType\": \"\",\n  \"fileSize\": 0\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/messages/{{chatId}}",
              "host": [
