{
  "info": {
    "_postman_id": "4e2fd0a5-1d6a-4e52-8fd1-5d6f2d36a901",
    "name": "ChatHub API",
    "description": "Postman collection for the ChatHub Go backend. Import the local environment file and set `bearerToken` with a valid Clerk JWT/session token for authenticated requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{bearerToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000"
    },
    {
      "key": "wsUrl",
      "value": "ws://localhost:5000/ws"
    },
    {
      "key": "bearerToken",
      "value": ""
    },
    {
      "key": "chatId",
      "value": ""
    },
    {
      "key": "participantUserId",
      "value": "user_2def456"
    },
    {
      "key": "query",
      "value": "hari"
    }
  ],
  "item": [
    {
      "name": "System",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "auth": {
              "type": "noauth"
            },
            "url": {
              "raw": "{{baseUrl}}/",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                ""
              ]
            },
            "description": "Public health check that returns plain text."
          }
        },
        {
          "name": "API Health",
          "request": {
            "method": "GET",
            "header": [],
            "auth": {
              "type": "noauth"
            },
            "url": {
