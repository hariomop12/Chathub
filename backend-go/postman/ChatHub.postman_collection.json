    {
      "name": "Webhooks",
      "item": [
        {
          "name": "Clerk Webhook",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "svix-id",
                "value": "msg_123"
              },
              {
                "key": "svix-timestamp",
                "value": "1710000000"
              },
              {
                "key": "svix-signature",
                "value": "v1,test_signature"
              }
            ],
            "auth": {
              "type": "noauth"
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"user.created\",\n  \"data\": {\n    \"id\": \"user_2abc123\",\n    \"username\": \"hariom\",\n    \"first_name\": \"Hariom\",\n    \"last_name\": \"Patel\",\n    \"primary_email_address_id\": \"email_123\",\n    \"email_addresses\": [\n      {\n        \"id\": \"email_123\",\n        \"email_address\": \"hariom@example.com\"\n      }\n    ],\n    \"image_url\": \"https://img.clerk.com/avatar.jpg\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/webhooks/clerk",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "webhooks",
                "clerk"
              ]
            },
            "description": "Clerk webhook endpoint. The signature headers above are placeholders; replace them with a real Svix signature when testing end to end."
          }
        }
      ]
    },
